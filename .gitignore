# build_it — Python .gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
.env

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.pytest_cache/
.coverage
htmlcov/
.tox/
*.xml

# PyInstaller binaries
*.spec
dist_bin/

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp

# Project-specific
# (don't commit the .build_it.yaml of Flutter projects used for local testing)
.build_it.yaml
